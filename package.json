{
  "name": "pi-paster",
  "version": "0.0.0",
  "description": "Pi extension that turns pasted image paths into first-class image attachments.",
  "keywords": [
    "image-attachments",
    "pi-extension",
    "pi-package"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "docs",
    "spec.md",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepare": "vp config",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@types/node": "^25.8.0",
    "@typescript/native-preview": "7.0.0-dev.20260515.1",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "packageManager": "pnpm@11.1.2",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
